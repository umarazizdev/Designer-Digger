// =============================================================================
// WARNING: This file is Designer-Digger rules ONLY.
// Your Firebase project has other apps — do NOT deploy this file alone.
// Use storage.rules.digger-snippet and merge into the Console instead.
// =============================================================================

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /digger_app/users/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /digger_app/products/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /digger_app/promotions/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
